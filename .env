# ============================
#   TeleCloud Configuration
# ============================

# Lấy tại: https://my.telegram.org → API development tools
API_ID=38727964
API_HASH=156373bcc07f30d53e827c25f63ddca2

# ID nhóm/kênh Telegram để lưu file
# Dùng "me" để lưu vào Saved Messages
# Hoặc ID dạng -100xxxxxxxxxx
LOG_GROUP_ID=-1003798905209

# Cổng server (mặc định: 8091)
PORT=80

# Kích thước upload tối đa (MB), 0 = tự động (2GB/4GB tùy tài khoản)
MAX_UPLOAD_SIZE_MB=0

# Đường dẫn database SQLite
DATABASE_PATH=./data/telecloud.db

# Thư mục ảnh thumbnail
THUMBS_DIR=./data/thumbs

# Thư mục tạm chứa chunks khi upload
TEMP_DIR=./data/temp

# FFmpeg path (để tạo thumbnail), đặt "disabled" nếu không có FFmpeg
FFMPEG_PATH=ffmpeg

# Proxy MTProto (tùy chọn): socks5://127.0.0.1:1080 hoặc http://...
PROXY_URL=

# Secret key để ký JWT token (đổi thành chuỗi ngẫu nhiên dài)
JWT_SECRET=A4d9f8b2e1c73a6f9d2e5b8c1a4f7d2e3b8c1a4f7b2e5c8a3f9d2e5b1c8f3a6
